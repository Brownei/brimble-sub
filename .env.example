# Brimble Platform - Environment Configuration
# Copy this file to .env and update values as needed

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=brimble
DB_PASSWORD=brimble
DB_NAME=brimble

# ==========================================
# Server Configuration
# ==========================================
APP_PORT=3333
APP_ENV=development

# ==========================================
# Client Configuration
# ==========================================
VITE_API_BASE_URL=http://api.localhost/v1

# ==========================================
# Caddy Configuration
# ==========================================
CADDY_DOMAIN=localhost
CADDY_API_DOMAIN=api.localhost

# ==========================================
# Docker Configuration
# ==========================================
COMPOSE_PROJECT_NAME=brimble
